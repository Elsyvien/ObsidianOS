{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ObsidianOS",
  "version": "0.1.0",
  "identifier": "com.maxwi.obsidianexamos",
  "build": {
    "beforeDevCommand": "npm run dev:desktop",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build:desktop",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ObsidianOS",
        "width": 1540,
        "height": 980,
        "minWidth": 1200,
        "minHeight": 780,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
